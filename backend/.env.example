NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Frontend origins (comma-separated) for CORS
# Para Spotify OAuth, use 127.0.0.1 no browser (localhost não é aceito pelo Spotify)
CORS_ORIGINS=http://127.0.0.1:5173,http://127.0.0.1:3000,http://localhost:5173,http://localhost:3000

JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Webhook protection
PAYMENT_WEBHOOK_SECRET=change-me
WEBHOOK_MAX_AGE_SECONDS=300

# Payment gateway: simulated | mercadopago
PAYMENT_GATEWAY=simulated

# Mercado Pago (sandbox/production access token)
MERCADOPAGO_ACCESS_TOKEN=
# Public Key (mesma tela de credenciais do MP — usada no front para cartão)
MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_WEBHOOK_SECRET=
MERCADOPAGO_API_BASE_URL=https://api.mercadopago.com
# Public URL for IPN/webhooks, e.g. https://your-domain.com/payments/webhook
MERCADOPAGO_NOTIFICATION_URL=
# E-mail de comprador de teste (painel MP). Usado quando o usuário tem e-mail .test / inválido para a API.
MERCADOPAGO_TEST_PAYER_EMAIL=
# CPF de comprador de teste (fallback quando o documento do usuário é inválido para a API)
MERCADOPAGO_TEST_PAYER_DOCUMENT=

# Supabase / Render / Railway: use a connection string (tem prioridade sobre DB_HOST)
# DATABASE_URL=postgresql://postgres.[ref]:[password]@host:port/database

# Docker / local sem URL única (recomendado com `docker compose up -d`):
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=app_db

# Railway / Upstash: URL completa (tem prioridade sobre REDIS_HOST)
# REDIS_URL=redis://default:senha@host:6379

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Job de reconciliação estoque Redis ↔ PostgreSQL (ms; 0 = desligado)
STOCK_RECONCILIATION_INTERVAL_MS=300000

# Spotify (Developer Dashboard: https://developer.spotify.com/dashboard)
# IMPORTANTE: desde abril/2025 o Spotify NÃO aceita "localhost" na Redirect URI.
# Use loopback IPv4 com HTTP: http://127.0.0.1:PORTA/caminho
# Ou HTTPS (ngrok, deploy, etc.) para outros hosts.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/auth/spotify/callback
SPOTIFY_FRONTEND_RETURN_URL=http://127.0.0.1:5173/eventos

# Apple Wallet (passkit-generator)
APPLE_WWDR_CERT_PATH=./certs/wwdr.pem
APPLE_SIGNER_CERT_PATH=./certs/signerCert.pem
APPLE_SIGNER_KEY_PATH=./certs/signerKey.pem
APPLE_SIGNER_KEY_PASSPHRASE=your-passphrase
APPLE_TEAM_ID=YOUR_TEAM_ID
APPLE_PASS_TYPE_IDENTIFIER=pass.com.yourcompany.ticket
APPLE_ORGANIZATION_NAME=Your Company
APPLE_PASS_MODEL_PATH=./assets/event.pass

# Google Wallet — local: arquivo JSON | Railway/produção: GOOGLE_WALLET_CREDENTIALS_JSON
GOOGLE_WALLET_CREDENTIALS_PATH=./certs/google-service-account.json
# GOOGLE_WALLET_CREDENTIALS_JSON={"type":"service_account",...}
GOOGLE_WALLET_ISSUER_ID=your_issuer_id
GOOGLE_WALLET_ISSUER_NAME=VIBRA
GOOGLE_WALLET_ORIGINS=http://127.0.0.1:5173,https://sistema-ticket.vercel.app
