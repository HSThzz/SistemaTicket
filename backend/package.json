{
  "name": "express-typeorm-api",
  "version": "1.0.0",
  "description": "API Node.js com Express, TypeScript, TypeORM e PostgreSQL",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only --ignore-watch node_modules src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typeorm": "typeorm-ts-node-commonjs -d src/shared/infrastructure/config/data-source.ts",
    "migration:generate": "npm run typeorm -- migration:generate",
    "migration:run": "npm run typeorm -- migration:run",
    "migration:revert": "npm run typeorm -- migration:revert",
    "migration:show": "npm run typeorm -- migration:show",
    "seed": "tsx src/seeds/run.ts",
    "seed:keep": "tsx src/seeds/run.ts --keep",
    "seed:prod": "node dist/seeds/run.js",
    "test": "cross-env NODE_ENV=test node --import tsx --test --test-concurrency=1 \"tests/**/*.test.ts\"",
    "test:integration": "npm run test",
    "docs": "typedoc"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "express-rate-limit": "^8.5.2",
    "googleapis": "^172.0.0",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.0",
    "jsonwebtoken": "^9.0.3",
    "passkit-generator": "^3.5.7",
    "pg": "^8.16.0",
    "pino": "^9.7.0",
    "pino-pretty": "^13.0.0",
    "rate-limit-redis": "^5.0.0",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.24",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.15.29",
    "@types/supertest": "^6.0.3",
    "cross-env": "^7.0.3",
    "supertest": "^7.1.0",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.19.4",
    "typedoc": "^0.28.19",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
