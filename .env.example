NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Frontend origins (comma-separated) for CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Webhook protection
PAYMENT_WEBHOOK_SECRET=change-me
WEBHOOK_MAX_AGE_SECONDS=300

# Payment gateway: simulated | mercadopago
PAYMENT_GATEWAY=simulated

# Mercado Pago (sandbox/production access token)
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=
MERCADOPAGO_API_BASE_URL=https://api.mercadopago.com
# Public URL for IPN/webhooks, e.g. https://your-domain.com/payments/webhook
MERCADOPAGO_NOTIFICATION_URL=

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=app_db

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Apple Wallet (passkit-generator)
APPLE_WWDR_CERT_PATH=./certs/wwdr.pem
APPLE_SIGNER_CERT_PATH=./certs/signerCert.pem
APPLE_SIGNER_KEY_PATH=./certs/signerKey.pem
APPLE_SIGNER_KEY_PASSPHRASE=your-passphrase
APPLE_TEAM_ID=YOUR_TEAM_ID
APPLE_PASS_TYPE_IDENTIFIER=pass.com.yourcompany.ticket
APPLE_ORGANIZATION_NAME=Your Company
APPLE_PASS_MODEL_PATH=./assets/event.pass

# Google Wallet (googleapis + JWT)
GOOGLE_WALLET_CREDENTIALS_PATH=./certs/google-service-account.json
GOOGLE_WALLET_ISSUER_ID=your_issuer_id
GOOGLE_WALLET_ORIGINS=http://localhost:3000
